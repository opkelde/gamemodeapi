{
  "Mqtt": {
    "Host": "homeassistant.local",
    "Port": 1883,
    "Username": "",
    "Password": "",
    "UseTls": false,
    "ClientId": "GameDetect",
    "DiscoveryPrefix": "homeassistant"
  },
  "Detection": {
    "PollIntervalSeconds": 5,
    "DebounceSeconds": 10,
    "EnableFullscreenDetection": true,
    "EnableLauncherScanning": true,
    "LauncherRescanIntervalMinutes": 60
  },
  "Service": {
    "DeviceId": "auto",
    "DeviceName": "Gaming PC",
    "LogLevel": "Information"
  }
}

